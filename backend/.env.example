# ─────────────────────────────────────────────────────────────────
# Sany Adventures — Backend Environment Configuration
# STEP 1: Copy this file:  copy .env.example .env
# STEP 2: Fill in your values below
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
ENABLE_JOBS=false

# ── Database ──────────────────────────────────────────────────────
# OPTION A: Neon / Supabase / any cloud Postgres (recommended)
# Get this from your Neon dashboard → Connection Details → Connection string
# Use Neon pooled endpoint. Keep sslmode=require for broad compatibility.
# DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# OPTION B: Local PostgreSQL
# Comment out DATABASE_URL above and fill these in instead:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sanyadventures
DB_USER=postgres
DB_PASSWORD=your_local_postgres_password
# DB_SSL=false   ← uncomment this for local Postgres without SSL

# ── JWT ───────────────────────────────────────────────────────────
# Generate a strong secret (run in terminal):
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# ── Admin seed account ────────────────────────────────────────────
ADMIN_EMAIL=admin@sanyadventures.com
ADMIN_PASSWORD=Admin@1234
ADMIN_NAME=Super Admin

# ── M-PESA (optional — simulation works without these) ───────────
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey
# Add the callback token to the URL query string so only trusted callbacks are processed.
MPESA_CALLBACK_TOKEN=replace_with_a_long_random_string
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa/callback?token=replace_with_a_long_random_string
MPESA_ENV=sandbox

# ── File uploads ──────────────────────────────────────────────────
# Option A — Cloudinary CDN (recommended for production)
# Free at cloudinary.com — 25GB storage + automatic CDN + image optimisation
# Get your URL from Dashboard → API Keys → "API Environment variable"
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
#
# Or set the three vars separately:
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
#
# Option B — Local disk (development only, breaks on multi-server deploy)
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ── CORS (frontend URL) ───────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── Redis (optional but recommended for multi-instance scaling) ──────────────
# Enables shared auth cache and future shared rate limits / queues.
# Example:
# REDIS_URL=redis://default:password@localhost:6379
# The same Redis instance is used for auth cache, shared rate limits, and background job queues.
REDIS_URL=
REDIS_PREFIX=eventflow

# Optional DB timeouts (milliseconds)
DB_CONN_TIMEOUT=15000
DB_STATEMENT_TIMEOUT=20000
DB_QUERY_TIMEOUT=25000

# Retry strategy for transient cloud DB issues (cold starts/network jitter)
DB_RETRY_ATTEMPTS=2
DB_RETRY_BASE_MS=800
DB_BOOT_RETRIES=4
DB_BOOT_RETRY_DELAY=1500

# Pool tuning
DB_POOL_MAX=8
DB_POOL_MIN=0
DB_IDLE_TIMEOUT=30000
DB_KEEP_ALIVE=true
DB_KEEP_ALIVE_DELAY=10000
DB_MAX_USES=7500

# ── Email (optional — app works without this) ────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_gmail_app_password
# SMTP_FROM="Sany Adventures <no-reply@sanyadventures.com>"
