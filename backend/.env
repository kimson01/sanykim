# ─────────────────────────────────────────────────────────────────
# Sany Adventures — Backend Environment Configuration
# STEP 1: Copy this file:  copy .env.example .env
# STEP 2: Fill in your values below
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────
# OPTION A: Neon / Supabase / any cloud Postgres (recommended)
# Get this from your Neon dashboard → Connection Details → Connection string
DATABASE_URL=postgresql://neondb_owner:npg_hX8lzJg0aMIS@ep-late-dust-adty3har-pooler.c-2.us-east-1.aws.neon.tech/neondb?sslmode=verify-full&channel_binding=require

# OPTION B: Local PostgreSQL
# Comment out DATABASE_URL above and fill these in instead:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sanyadventures
DB_USER=postgres
DB_PASSWORD=your_local_postgres_password
# DB_SSL=false   ← uncomment this for local Postgres without SSL

# ── JWT ───────────────────────────────────────────────────────────
# Generate a strong secret (run in terminal):
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# ── Admin seed account ────────────────────────────────────────────
ADMIN_EMAIL=admin@sanyadventures.com
ADMIN_PASSWORD=Admin@1234
ADMIN_NAME=Super Admin

# ── M-PESA (optional — simulation works without these) ───────────
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa/callback
MPESA_ENV=sandbox

# ── File uploads ──────────────────────────────────────────────────
# Option A — Cloudinary CDN (recommended for production)
# Free at cloudinary.com — 25GB storage + automatic CDN + image optimisation
# Get your URL from Dashboard → API Keys → "API Environment variable"
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
#
# Or set the three vars separately:
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
#
# Option B — Local disk (development only, breaks on multi-server deploy)
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ── CORS (frontend URL) ───────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── Email (optional — app works without this) ────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_gmail_app_password
# SMTP_FROM="Sany Adventures <no-reply@sanyadventures.com>"
